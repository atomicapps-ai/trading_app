# .env.example — copy to .env and fill in real values.
# .env is on Drive (accepted risk per CLAUDE.md storage rules) and gitignored.

# TradeStation OAuth credentials. Required for paper + live modes.
# See the Setup Guide on /broker for the one-time OAuth dance to obtain
# the initial refresh token.
TS_CLIENT_ID=your_client_id_here
TS_CLIENT_SECRET=your_client_secret_here
TS_REFRESH_TOKEN=your_refresh_token_here
TS_ACCOUNT_ID=your_account_id_here

# Sim vs live API endpoint. true → sim-api.tradestation.com, false → api.tradestation.com.
# Independent of `mode` in settings.yaml; you can run mode=paper against sim or live.
TS_SIM=true

# --- Phase 4 ---

# Alpaca News API — primary news source (Benzinga-sourced). Free with
# any Alpaca account; broker execution still routes through TradeStation,
# we use Alpaca for news/data only.
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_API_SECRET=your_alpaca_secret_here

# OPTIONAL: Alpha Vantage sentiment enrichment. 25 calls/day free tier.
# If unset, the sentiment lens falls back to VADER-only scoring on
# Alpaca headlines (backtest-safe, no rate limit). Leave blank to disable.
ALPHA_VANTAGE_KEY=

# Finviz politeness — delay between HTML screener requests.
FINVIZ_DELAY_SECONDS=1.5

# Alpaca News politeness — delay between API calls.
ALPACA_NEWS_DELAY_SECONDS=0.25

# SEC EDGAR requires a real User-Agent with a contact email. Set it
# to something like: "TradeAgent/0.1 (contact: you@example.com)".
SEC_USER_AGENT=TradeAgent/0.1 (contact: set_me@example.com)

# --- FX (OANDA v20) — for the FVG-continuation FX strategy ---
# Free PRACTICE account: oanda.com → open practice account → AMP →
# "Manage API Access" → generate personal access token. No monthly API fee.
# Use BROKER_PROVIDER=oanda (or add an 'oanda' account row on /broker).
OANDA_API_TOKEN=your_oanda_token_here
OANDA_ACCOUNT_ID=101-001-0000000-001
OANDA_ENV=practice          # practice | live  (keep practice until verified)

# --- Broker selection (cross-machine) ---
# The active broker is chosen by the /broker account registry (in the DB).
# But the DB is NOT in git — so on a fresh machine with an empty registry,
# this env var selects the broker instead. Set it to make IBKR the default
# everywhere without re-adding an account per machine.
#   alpaca (default) | ibkr | tradestation | oanda
BROKER_PROVIDER=ibkr

# --- Interactive Brokers (FX + futures + stocks + options) ---
# IBKR's API talks to a LOCAL gateway, not a cloud endpoint. Run IB Gateway
# (headless) or TWS with "Enable ActiveX and Socket Clients" ON, then connect.
# Ports: IB Gateway paper 4002 / live 4001 ; TWS paper 7497 / live 7496.
# No API keys — auth is the gateway login. pip install ib_insync (or ib_async).
IBKR_HOST=127.0.0.1
IBKR_PORT=4002          # paper IB Gateway (use 4001 live / 7497 TWS-paper / 7496 TWS-live)
IBKR_CLIENT_ID=7        # any unique integer per connection (live trading adapter)
# IBKR_DATA_CLIENT_ID  # optional; candle fetches (/data-fetch source=ibkr) use this
                       # so a data pull never collides with the trading connection.
                       # Defaults to IBKR_CLIENT_ID + 20.

# Select the active broker when the account registry is empty:
#   alpaca (default, US stocks) | tradestation (stocks/futures) | oanda (FX) | ibkr (FX+futures+stocks)
BROKER_PROVIDER=alpaca

# --- Web exposure / auth ---
# The app is a single-user tool with NO login by default. Before exposing it to
# the internet (Cloudflare Tunnel, traveling), set a password: every page then
# requires it, via a signed session cookie. Leave blank for local-only use.
# APP_AUTH_PASSWORD=choose-a-strong-passphrase
# Public origin the app is reached at once deployed. Used to build absolute
# links in phone-push notifications so tapping an alert opens the real site.
# PUBLIC_BASE_URL=https://app.tindex.ai
# Optional: explicit cookie-signing secret. If unset it's derived from the
# password (sessions still survive restarts). Set a random value to rotate/
# invalidate all sessions independently of the password.
# APP_SECRET_KEY=
